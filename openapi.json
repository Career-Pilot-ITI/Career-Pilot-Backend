onents/schemas/OtpAuthResponse"}}}},"410":{"description":"OTP expired","content":{"*/*":{"schema":{"$ref":"#/components/schemas/OtpAuthResponse"}}}},"429":{"description":"Lockout active — too many failed attempts"},"200":{"description":"OTP verified successfully","content":{"*/*":{"schema":{"$ref":"#/components/schemas/OtpAuthResponse"}}}}}}},"/api/v1/otp/send":{"post":{"tags":["OTP Authentication"],"summary":"Send OTP","description":"Send a one-time password to the user's phone number via SMS or WhatsApp.","operationId":"sendOtp","requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/SendOtpRequest"}}},"required":true},"responses":{"200":{"description":"OTP sent","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ApiResponse"}}}},"429":{"description":"Cooldown active, lockout active, or resend limit reached"}}}},"/api/v1/interviews/sessions":{"get":{"tags":["Interview Sessions"],"summary":"List user's interview sessions","operationId":"listSessions","responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ApiResponse"}}}}},"security":[{"bearerAuth":[]}]},"post":{"tags":["Interview Sessions"],"summary":"Start an interview session","description":"Creates a new IN_PROGRESS session for the given track and generates {questionCount} LLM-powered interview questions.","operationId":"startSession","requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/StartSessionRequest"}}},"required":true},"responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ApiResponse"}}}}},"security":[{"bearerAuth":[]}]}},"/api/v1/interviews/sessions/{sessionId}/questions/{questionId}/answer":{"post":{"tags":["Interview Sessions"],"summary":"Submit an answer for a session question","description":"Stores transcript + word timings, computes pacing metrics server-side, and triggers LLM scoring. Cannot submit to a COMPLETED or ABANDONED session.","operationId":