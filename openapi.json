{"openapi":"3.0.1","info":{"title":"Career Pilot API","description":"Backend API for The Career Pilot  authentication & authorization service","version":"1.0.0"},"servers":[{"url":"http://localhost:8080","description":"Generated server url"}],"security":[{"bearerAuth":[]}],"tags":[{"name":"Interview Sessions","description":"Session lifecycle and question answer submission"},{"name":"User Profile","description":"View and update user profile, skills, and CV"},{"name":"OTP Authentication","description":"Phone-based OTP signup and authentication"},{"name":"Tracks","description":"Career tracks CRUD (admin) and listing (public)"},{"name":"Authentication","description":"Email/password authentication, OAuth, and token management"},{"name":"Coin Wallet","description":"Coin balance and top-up via Paymob"},{"name":"Payments","description":"Paymob checkout initiation, webhook confirmation, and transaction history"},{"name":"Files","description":"File upload for avatars, resumes, and CVs"}],"paths":{"/api/v1/auth/verify":{"put":{"tags":["Authentication"],"summary":"[DEPRECATED] Verify email","description":"Use POST /api/v1/otp/verify instead. OTP verification replaces email verification.","operationId":"verifyUser","requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/VerifyRequest"}}},"required":true},"responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ApiResponse"}}}}},"deprecated":true}},"/api/v1/auth/reset-password":{"put":{"tags":["Authentication"],"summary":"[DEPRECATED] Reset password","description":"Password reset via email is deprecated. OTP-based auth uses phone verification.","operationId":"resetPassword","parameters":[{"name":"email","in":"query","required":true,"schema":{"type":"string"}},{"name":"verificationCode","in":"query","required":true,"schema":{"type":"string"}},{"name":"newPassword","in":"query","required":true,"schema":{"type":"string"}}],"responses":{"200":{"description":"OK","con