# Database
DB_NAME=career_pilot
DB_USERNAME=career_pilot
DB_PASSWORD=changeme

# Redis
REDIS_PASSWORD=changeme

# JWT
JWT_SECRET=base64-encoded-256-bit-secret-key-here
JWT_TIME=3600000

# OAuth2 - Google
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# OAuth2 - GitHub
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Mail (Gmail SMTP)
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# OTP
OTP_PROVIDER=simulated
WIREWEB_API_KEY=
WIREWEB_SESSION_ID=
WIREWEB_BASE_URL=

# LLM — OpenAI/Gemini (default, openai profile is active by default)
LLM_API_KEY=your-api-key-here
LLM_MODEL=gemini-3.1-flash-lite
LLM_TEMPERATURE=0.4
OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# Ollama (use -P ollama):
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3

# App
URI_APP=http://localhost:5173
REDIRECT_URI_BASE=http://localhost:8080
